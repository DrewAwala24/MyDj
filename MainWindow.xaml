<Window x:Class="MyPersonalDjGui.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:MyPersonalDjGui"
        mc:Ignorable="d"
        Title="MainWindow" Height="450" Width="800">
    <Grid Background="#2D2D30">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <ListBox x:Name="SongListBox" 
             Margin="20"
             Background="#3E3E42" 
             Foreground="White" 
             FontSize="14" 
             BorderThickness="0"
             Grid.Row="1" MouseDoubleClick="SongListBox_MouseDoubleClick" />

        <StackPanel Orientation="Horizontal" Grid.Row="0" Margin="12" HorizontalAlignment="Left">
            <Button x:Name="PlayButton" Width="80" Margin="4" Click="PlayButton_Click">Play</Button>
            <Button x:Name="PauseButton" Width="80" Margin="4" Click="PauseButton_Click">Pause</Button>
            <Button x:Name="StopButton" Width="80" Margin="4" Click="StopButton_Click">Stop</Button>
            <Button x:Name="ShuffleButton" Width="80" Margin="4" Click="ShuffleButton_Click">Shuffle</Button>
            <TextBlock x:Name="DebugBanner"
                       Margin="12,0,0,0"
                       Foreground="Yellow"
                       FontSize="16"
                       FontWeight="Bold"
                       VerticalAlignment="Center"
                       Panel.ZIndex="1" />
        </StackPanel>

        <TextBlock x:Name="StatusText"
                   Grid.Row="2"
                   Margin="20,0,20,6"
                   Foreground="White"
                   FontSize="12"/>

        
    </Grid>
</Window>
